graph LR
    A[(Raw Time Series)] --> B[LagsAdder]
    B --> C[WeatherFeatureAdders]
    C --> D[CyclicFeaturesAdder]
    D --> E[DaylightFeatureAdder]
    E --> F[(Enriched Feature Matrix)]
    B -.->|"Historical load lags"| B
    C -.->|"Temp; wind; radiation"| C
    D -.->|"Hour and week cycles"| D
    E -.->|"Sunrise and sunset"| E
    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000
    class B,C,D,E primary
    class A,F secondary