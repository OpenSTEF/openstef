graph TD
    A[Input Data] --> B[Path 1: Direct Quantile]
    A --> C[Path 2: Post-hoc]
    B --> D[Quantile Regression Model]
    D --> E[P10 / P50 / P90 Direct]
    C --> F[Point Forecast Model]
    F --> G[Single Prediction]
    G --> H[ConfidenceIntervalApplicator]
    H --> I[Adds Uncertainty Bands]
    I --> J[P10 / P50 / P90 Output]
    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000
    class A accent
    class B,C secondary
    class D,F primary
    class G,H primary
    class E,I,J secondary