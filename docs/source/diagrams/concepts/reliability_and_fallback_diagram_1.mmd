graph TD
    A[Input Data Arrives] --> B{Validation Checks}
    B -->|Complete and valid| C[Primary Model Predicts]
    B -->|Flatline or incomplete| F[Fallback Forecaster]
    C --> D{Model OK?}
    D -->|Success| E[Output Forecast]
    D -->|Fails or stale| F
    F --> E
    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000
    classDef decision fill:#fff,stroke:#1E3A5F,stroke-width:2px,color:#000
    class A,C primary
    class F,E secondary
    class B,D accent