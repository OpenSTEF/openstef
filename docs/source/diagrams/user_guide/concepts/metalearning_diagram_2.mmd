graph LR
    A[Base Predictions N Forecasters] --> B[LGBM Classifier Per Quantile]
    B -->|predict_proba| C[Soft Probability Weights]
    C --> D[Multiply Base Predictions]
    A --> D
    D --> E[Weighted Average]
    E --> F[Final Quantile Forecast]
    G([Weights sum to 1]) -.-> C
    H([Blends existing predictions]) -.-> E
    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000
    class A,D,E primary
    class B,C,F secondary
    class G,H accent