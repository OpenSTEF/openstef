graph TD
    A[Presets Layer] --> B[ForecastingWorkflowConfig]
    B --> C[create_forecasting_workflow]
    C --> D[CustomForecastingWorkflow]
    D --> E[Callbacks and Lifecycle]
    D --> F[ForecastingModel]
    F --> G[Preprocessing Pipeline]
    G --> H[Forecaster]
    H --> I[Postprocessing Pipeline]

    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000

    class A,B,C accent
    class D,E secondary
    class F primary
    class G,H,I primary