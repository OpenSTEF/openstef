graph LR
    A[(VersionedTimeSeriesDataset)] --> B[filter_by_lead_time]
    B --> C[(Filtered Dataset)]
    C --> D[select_version]
    D --> E[(TimeSeriesDataset)]

    F[All versions and lead times] -.-> A
    G[Only rows with sufficient lead time] -.-> C
    H[One value per timestamp] -.-> E

    classDef primary fill:#00D9C5,stroke:#1E3A5F,stroke-width:2px,color:#000
    classDef secondary fill:#1E3A5F,stroke:#00D9C5,stroke-width:2px,color:#fff
    classDef accent fill:#e6f7f5,stroke:#00D9C5,stroke-width:2px,color:#000

    class B,D primary
    class A,C,E secondary
    class F,G,H accent